<animated-selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:id="@+id/on"
        android:drawable="@drawable/ic_round_flash_on"
        android:state_checked="true" />
    <item
        android:id="@+id/off"
        android:drawable="@drawable/ic_round_flash_off" />
    <transition
        android:fromId="@id/off"
        android:toId="@id/on"
        android:drawable="@drawable/ic_round_flash_off_to_on" />
    <transition
        android:fromId="@id/on"
        android:toId="@id/off"
        android:drawable="@drawable/ic_round_flash_on_to_off" />
</animated-selector>
